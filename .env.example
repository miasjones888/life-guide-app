# Google OAuth credentials
# Create at: https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# Application type: Desktop app (for first-time token generation)
GOOGLE_CLIENT_ID=

GOOGLE_CLIENT_SECRET=

# Generated by: node scripts/get-refresh-token.js (run once, then paste here)
GOOGLE_REFRESH_TOKEN=

# Your Google Calendar ID — "primary" works for the main calendar
GOOGLE_CALENDAR_ID=primary

# From: https://console.anthropic.com → API Keys
# Optional — app works without it, just no Morning Brief digest
ANTHROPIC_API_KEY=
